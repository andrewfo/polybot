# === REQUIRED: Polymarket ===
# Get these from: https://docs.polymarket.com/ (API credentials section)
# You need to: 1) Create a Polymarket account, 2) Fund with USDC on Polygon, 3) Generate API keys
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# === REQUIRED: Wallet ===
# Your Polygon wallet private key (the one linked to your Polymarket account)
# NEVER share this. NEVER commit this.
PRIVATE_KEY=

# === REQUIRED: Polygon RPC ===
# Free public endpoint works but is rate-limited. For better reliability, get a free key from Alchemy or Infura.
POLYGON_RPC_URL=https://polygon-rpc.com

# === REQUIRED: OpenRouter ===
# Sign up at https://openrouter.ai/ and add credits ($5-10 to start)
# This is used for LLM calls (signal analysis, probability estimation)
OPENROUTER_API_KEY=

# === OPTIONAL: Telegram Notifications ===
# To set up: run `python scripts/setup_telegram.py` and follow the instructions
# If not set, notifications will print to stdout instead
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === OPTIONAL: Serper.dev Web Search ===
# Free: 2,500 searches/month. Sign up at https://serper.dev
# Provides structured Google search results for market analysis
# SERPER_API_KEY=

# === OPTIONAL: The Odds API (Sports Betting) ===
# Free: 500 requests/month. Sign up at https://the-odds-api.com
# Provides bookmaker odds from 40+ sportsbooks for sports markets
# ODDS_API_KEY=

# === OPTIONAL: Congress.gov API (Political/Legislative) ===
# Free: 5,000 requests/hour. Get key at https://api.congress.gov/sign-up/
# Provides bill status, votes, and legislative activity
# CONGRESS_API_KEY=

# === OPTIONAL: Perplexity Sonar (Search-Grounded LLM) ===
# Uses OpenRouter (no separate key needed). Cost: ~$1/M tokens
# Model performs live web searches and returns cited results
# SONAR_MODEL=perplexity/sonar

# === OPTIONAL: Model Overrides ===
# Cheap model for routine tasks (default: free Gemini Flash)
# CHEAP_MODEL=google/gemini-2.0-flash-exp:free
# Frontier model for high-stakes decisions (default: Claude Opus 4.6)
# FRONTIER_MODEL=anthropic/claude-opus-4-6
