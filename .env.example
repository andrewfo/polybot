# ============================================================================
# POLYMARKET SIGNAL-BASED TRADING BOT — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments. Uncomment to override defaults.

# === REQUIRED: Polymarket CLOB API ===
# Get these from: https://docs.polymarket.com/ (API credentials section)
# You need to: 1) Create a Polymarket account, 2) Fund with USDC on Polygon, 3) Generate API keys
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# === REQUIRED: Wallet ===
# Your Polygon wallet private key (the one linked to your Polymarket account)
# NEVER share this. NEVER commit this.
PRIVATE_KEY=

# === REQUIRED: Polygon RPC ===
# Free public endpoint works but is rate-limited.
# For better reliability, get a free key from Alchemy or Infura.
POLYGON_RPC_URL=https://polygon-rpc.com

# === REQUIRED: OpenRouter ===
# Sign up at https://openrouter.ai/ and add credits ($5-10 to start)
# Powers all LLM calls (signal analysis, categorization, probability estimation)
OPENROUTER_API_KEY=

# === EXECUTION MODE ===
# true = simulated fills, no real orders (safe for testing)
# false = live limit orders via CLOB API (real money!)
PAPER_TRADING=true

# === OPTIONAL: LLM Model Overrides ===
# Cheap model for routine tasks (categorization, extraction, summaries)
# CHEAP_MODEL=google/gemini-2.0-flash-lite-001
# Frontier model for final probability estimation and trade decisions
# FRONTIER_MODEL=anthropic/claude-opus-4-6
# Perplexity Sonar for search-grounded web signal (uses OpenRouter, no separate key)
# SONAR_MODEL=perplexity/sonar

# === OPTIONAL: Serper.dev Web Search ===
# Free: 2,500 searches/month. Sign up at https://serper.dev
# SERPER_API_KEY=

# === OPTIONAL: Telegram Notifications ===
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === OPTIONAL: Trading Parameters ===
# KELLY_FRACTION=0.25              # Quarter Kelly (conservative)
# MIN_EDGE_THRESHOLD=0.03          # Only trade when edge > 3%
# MAX_POSITION_PCT=0.10            # Max 10% of bankroll per market
# MIN_BANKROLL_RESERVE=20          # Always keep $20 USDC untouched
# TEST_BANKROLL=1000               # Paper trading bankroll ($1000)

# === OPTIONAL: Market Filtering ===
# MIN_MARKET_LIQUIDITY=500         # Min liquidity to consider ($)
# MAX_MARKET_LIQUIDITY=500000      # Max liquidity to consider ($)
# MIN_HOURS_TO_RESOLUTION=72       # Skip markets expiring in < 3 days
# MAX_DAYS_TO_RESOLUTION=30        # Skip markets expiring in > 30 days
# MAX_SPREAD=0.10                  # Max bid-ask spread (10%)
# MIN_24H_VOLUME=100               # Min 24h volume ($)

# === OPTIONAL: Risk Guardrails ===
# MAX_SIMULTANEOUS_POSITIONS=5     # Max open positions at once
# MAX_NEW_TRADES_PER_HOUR=3        # Rate limit on new trades
# MAX_DRAWDOWN_PCT=0.30            # Auto-stop if down 30% from peak
# MAX_DAILY_LOSS_PCT=0.15          # Auto-stop if down 15% in a day

# === OPTIONAL: Worker Intervals ===
# DISCOVERY_INTERVAL_MINUTES=120   # Market discovery cycle (default 2h)
# AGGREGATION_INTERVAL_MINUTES=240 # Signal aggregation cycle (default 4h)
# POSITION_CHECK_INTERVAL_MINUTES=30  # Position monitor cycle (default 30min)

# === OPTIONAL: Order Execution ===
# SLIPPAGE_BUFFER=0.02             # Limit price offset from best ask/bid
# STALE_ORDER_MINUTES=15           # Cancel unfilled orders after this
# POLYMARKET_FEE_RATE=0.02         # Polymarket's 2% profit fee

# === OPTIONAL: Order Book Depth ===
# DEPTH_ANALYSIS_ENABLED=true      # Analyze order book before trading
# MAX_ACCEPTABLE_SLIPPAGE=0.03     # Max 3% slippage, reduce size if exceeded
# MIN_DEPTH_USD=50                 # Skip if total book depth < $50

# === OPTIONAL: Signal Calibration ===
# MIN_CALIBRATION_SAMPLES=20       # Min resolved predictions for dynamic weights
# CALIBRATION_LOOKBACK_DAYS=90     # Rolling window for Brier scores

# === OPTIONAL: Frontier Divergence Guardrails ===
# MAX_DIVERGENCE_LOW_CONFIDENCE=0.40  # Max divergence when confidence < 0.7
# MAX_DIVERGENCE_ANY_CONFIDENCE=0.50  # Max divergence regardless of confidence
# MIN_CONFIDENCE_BLEND=0.50           # Floor for confidence blending

# === OPTIONAL: Aggregation ===
# USE_LOG_ODDS_AVERAGING=false     # Log-odds averaging (more calibrated at extremes)
# SONAR_RATE_LIMIT=20              # Perplexity Sonar calls per minute

# === OPTIONAL: Web Dashboard ===
# WEB_PORT=8080                    # FastAPI backend port

# === OPTIONAL: Notifications ===
# NOTIFICATIONS_ENABLED=true       # Enable web log panel notifications
